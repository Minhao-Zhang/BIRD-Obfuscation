# Copy this file to .env and fill in real values. .env is gitignored.

# Used by pipeline/eval_contamination.py (contamination check), eval_ablation.py,
# probe_schema_recall.py, and the cheap-model steps 08/09 (decoy + paraphrase)
OPENAI_API_KEY=

# --- Database connections (optional) --------------------------------------- #
# The four PostgreSQL instances the eval + pipeline talk to. Each defaults to the
# local docker-compose instance shown below, so a LOCAL run needs none of these.
# Override them (full libpq DSN per instance) to point the eval at remote Postgres
# — e.g. AWS RDS. The local default uses 127.0.0.1 (never localhost) deliberately;
# see docs/reference/pipeline-invariants.md.
#
# PG_BASE_DSN="host=127.0.0.1 port=5432 dbname=bird user=bird password=bird"
# PG_RENAME_DSN="host=127.0.0.1 port=5433 dbname=bird user=bird password=bird"
# PG_DECOY_DSN="host=127.0.0.1 port=5434 dbname=bird user=bird password=bird"
# PG_RENAME_DECOY_DSN="host=127.0.0.1 port=5435 dbname=bird user=bird password=bird"
#
# Example — four databases on one remote server (AWS RDS), TLS required:
# PG_BASE_DSN="host=bird.abc123.us-east-1.rds.amazonaws.com port=5432 dbname=bird_base user=bird password=... sslmode=require"
# PG_RENAME_DSN="host=bird.abc123.us-east-1.rds.amazonaws.com port=5432 dbname=bird_rename user=bird password=... sslmode=require"
# PG_DECOY_DSN="host=bird.abc123.us-east-1.rds.amazonaws.com port=5432 dbname=bird_decoy user=bird password=... sslmode=require"
# PG_RENAME_DECOY_DSN="host=bird.abc123.us-east-1.rds.amazonaws.com port=5432 dbname=bird_rename_decoy user=bird password=... sslmode=require"
